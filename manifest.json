{
  "manifest_version": 3,
  "name": "Context Relay",
  "version": "1.1",
  "description": "跨平台AI对话迁移工具 — 在多个大语言模型间无缝传递上下文，保留推理过程",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://kimi.com/*",
        "*://kimi.moonshot.cn/*",
        "*://chat.deepseek.com/*",
        "*://www.perplexity.ai/*",
        "*://grok.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "selectors.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "host_permissions": [
    "*://claude.ai/*",
    "*://chatgpt.com/*",
    "*://gemini.google.com/*",
    "*://kimi.com/*",
    "*://kimi.moonshot.cn/*",
    "*://chat.deepseek.com/*",
    "*://www.perplexity.ai/*",
    "*://grok.com/*"
  ]
}